---
import Flower from './Flower.astro';
---

<div
  class="brands-wrapper bg-black px-pageXMobile md:px-pageX text-white overflow-x-hidden relative z-10 min-h-screen flex items-center"
>
  <div class="container gap-4 md:gap-8 py-[12vh] md:py-[14vh] scrollx items-stretch" id="why-work-with-me">
      <div
        class="bg-primary brands-section pin p-8 md:p-10 min-w-[33%] md:min-w-[50%] lg:min-w-[44%] xl:min-w-[36%] 2xl:min-w-[30%] rounded-3xl relative overflow-hidden"
      >
        <div
          class="text-[2.2rem] md:text-[3rem] lg:text-[4rem] leading-[1.05] text-background font-[700] z-[1] absolute top-8 left-8 lg:top-1/2 lg:left-[78%] lg:-rotate-90 lg:-translate-x-3/4 lg:-translate-y-1/2 w-[80%] lg:w-full"
        >
          Why Work <br /> With Me?
        </div>
        <div
          class="absolute top-0 -left-[62%] md:-left-[50%] lg:-left-[42%] xl:-left-[35%] 2xl:-left-[36%] translate-x-1/2 opacity-40"
        >
          <Flower />
        </div>
      </div>
      <div
        class="bg-darkBackground brands-section pin min-w-[33%] md:min-w-[50%] lg:min-w-[44%] xl:min-w-[36%] 2xl:min-w-[30%] p-8 md:p-10 rounded-3xl border border-darkBorder"
      >
        <span
          class="anim text-textDullest text-[1.8rem] md:text-[3rem] lg:text-[4rem]"
          >01</span
        >
        <h2
          class="text-textLightPrimary font-bold text-left text-[1.8rem] md:text-[2rem] z-[1] lg:text-[2.4rem] mb-[20px] tracking-[3px] md:tracking-[5px] uppercase"
        >
          Diverse <br /> Experience
        </h2>

        <div class="col z-1 relative">
          <p
            class="text-textDullest w-full max-w-[55ch] font-[300] text-[1.1rem] leading-[1.6] md:text-[1.25rem] text-left md:leading-[1.7]"
          >
            I've cultivated a versatile skillset through my experiences with
            startups, software houses, and service-based companies, ensuring I
            am well-equipped to tackle any challenge.
          </p>
        </div>
      </div>
      <div
        class="bg-darkBackground brands-section pin min-w-[33%] md:min-w-[50%] lg:min-w-[44%] xl:min-w-[36%] 2xl:min-w-[30%] p-8 md:p-10 rounded-3xl border border-darkBorder"
      >
        <span
          class="anim text-textDullest text-[1.8rem] md:text-[3rem] lg:text-[4rem]"
          >02</span
        >
        <h2
          class="text-textLightPrimary anim text-left font-bold text-[1.8rem] md:text-[2rem] z-[1] lg:text-[2.4rem] mb-[20px] tracking-[3px] md:tracking-[5px] uppercase"
        >
          Framework <br /> Independent
        </h2>

        <div class="col anim z-1 relative">
          <p
            class="text-textDullest w-full max-w-[55ch] font-[300] text-[1.1rem] leading-[1.6] md:text-[1.25rem] text-left md:leading-[1.7]"
          >
            As an Engineer, my expertise extends beyond specific languages or
            frameworks. Instead, I'm adept at selecting the most suitable
            technology as per project requirement.
          </p>
        </div>
      </div>
      <div
        class="bg-darkBackground brands-section pin min-w-[33%] md:min-w-[50%] lg:min-w-[44%] xl:min-w-[36%] 2xl:min-w-[30%] p-8 md:p-10 rounded-3xl border border-darkBorder"
      >
        <span
          class="anim text-textDullest text-[1.8rem] md:text-[3rem] lg:text-[4rem]"
          >03</span
        >
        <h2
          class="text-textLightPrimary anim text-left font-bold text-[1.8rem] md:text-[2rem] z-[1] lg:text-[2.4rem] mb-[20px] tracking-[3px] md:tracking-[5px] uppercase"
        >
          Future <br /> Ready
        </h2>

        <div class="col anim z-1 relative">
          <p
            class="text-textDullest w-full max-w-[55ch] font-[300] text-[1.1rem] leading-[1.6] md:text-[1.25rem] text-left md:leading-[1.7]"
          >
            Keeping abreast of the latest technological trends is paramount to
            my success. This dedication ensures that I deliver cutting-edge
            solutions that propel your projects forward.
          </p>
        </div>
      </div>
      <div
        class="bg-darkBackground brands-section pin min-w-[33%] md:min-w-[50%] lg:min-w-[44%] xl:min-w-[36%] 2xl:min-w-[30%] p-8 md:p-10 rounded-3xl border border-darkBorder"
      >
        <span
          class="anim text-textDullest text-[1.8rem] md:text-[3rem] lg:text-[4rem]"
          >04</span
        >
        <h2
          class="text-textLightPrimary anim text-left font-bold text-[1.8rem] md:text-[2rem] z-[1] lg:text-[2.4rem] mb-[20px] tracking-[3px] md:tracking-[5px] uppercase"
        >
          Result <br /> Driven
        </h2>

        <div class="col anim z-1 relative">
          <p
            class="text-textDullest w-full max-w-[55ch] font-[300] text-[1.1rem] leading-[1.6] md:text-[1.25rem] text-left md:leading-[1.7]"
          >
            Delivering exceptional results is my unwavering goal. I'm committed
            to going above and beyond expectations to ensure your success. Your
            satisfaction is my driving force.
          </p>
        </div>
      </div>
      <div
        class="bg-darkBackground brands-section pin min-w-[33%] md:min-w-[50%] lg:min-w-[44%] xl:min-w-[36%] 2xl:min-w-[30%] p-8 md:p-10 rounded-3xl border border-darkBorder"
      >
        <span
          class="anim text-textDullest text-[1.8rem] md:text-[3rem] lg:text-[4rem]"
          >05</span
        >
        <h2
          class="text-textLightPrimary anim text-left font-bold text-[1.8rem] md:text-[2rem] z-[1] lg:text-[2.4rem] mb-[20px] tracking-[3px] md:tracking-[5px] uppercase"
        >
          Team <br /> Player
        </h2>

        <div class="col anim z-1 relative">
          <p
            class="text-textDullest w-full max-w-[55ch] font-[300] text-[1.1rem] leading-[1.6] md:text-[1.25rem] text-left md:leading-[1.7]"
          >
            I thrive in collaborative environments and value the input of
            others. Your input is highly valued, and together, we can transform
            your projects into resounding achievements.
          </p>
        </div>
      </div>
  </div>
</div>

<style>
  .container {
    display: flex;
    width: max-content;
  }
  .brands-section {
    min-width: 82vw !important;
    flex: 0 0 82vw;
    min-height: 62vh;
  }
  @media (min-width: 768px) {
    .brands-section {
      min-width: 58vw !important;
      flex-basis: 58vw;
      min-height: 64vh;
    }
  }
  @media (min-width: 1024px) {
    .brands-section {
      min-width: 48vw !important;
      flex-basis: 48vw;
      min-height: 66vh;
    }
  }
  @media (min-width: 1280px) {
    .brands-section {
      min-width: 40vw !important;
      flex-basis: 40vw;
      min-height: 68vh;
    }
  }
  @media (min-width: 1536px) {
    .brands-section {
      min-width: 34vw !important;
      flex-basis: 34vw;
      min-height: 70vh;
    }
  }
  .container section p {
    width: 100%;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  const wrapper = document.querySelector('.brands-wrapper') as HTMLElement | null;
  const container = document.querySelector('.container') as HTMLElement | null;

  if (wrapper && container) {
    const getScrollAmount = () => Math.max(0, container.scrollWidth - wrapper.clientWidth);

    gsap.to(container, {
      x: () => -getScrollAmount(),
      ease: 'none',
      scrollTrigger: {
        trigger: wrapper,
        start: 'top top',
        pin: true,
        scrub: 1,
        end: () => `+=${getScrollAmount()}`,
        invalidateOnRefresh: true,
      },
    });
  }
</script>
