---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/Hero/HeroSection.astro';
import Story from '../components/Story/Story.astro';
import Summary from '../components/Summary/Summary.astro';
import Footer from '../components/Footer/Footer.astro';
import MouseTrailer from '../components/MouseTrailer/MouseTrailer.astro';
import WhyWorkWithMe from '../components/WhyWorkWithMe/WhyWorkWithMe.astro';
import Marquee from '../components/Marquee/Marquee.astro';
import Preloader from '../components/Preloader/Preloader.astro';
import Projects from '../components/Projects/Projects.astro';
---

<Layout title="Nadir Khan">
  <Preloader />
  <MouseTrailer />
  <div class="section-reveal">
    <HeroSection />
  </div>
  <div class="block md:hidden">
    <Marquee text="The Story I told my wife" />
  </div>
  <Story />
  <div class="section-reveal">
    <Marquee text="My Projects I Work On" />
  </div>
  <div class="section-reveal">
    <Projects />
  </div>
  <div class="section-reveal">
    <Marquee text="A Developer With Magical Touch" />
  </div>
  <div class="section-reveal">
    <WhyWorkWithMe />
  </div>
  <div class="section-reveal">
    <Marquee text="Lorem ipsum dolor? Just Kidding" />
  </div>
  <div class="section-reveal">
    <Summary />
  </div>
  <div class="section-reveal">
    <Footer />
  </div>
</Layout>
